# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── API credentials — NEVER commit ───────────────────────────────────────────
.env

# ── Audio files (large — upload directly to RunPod) ──────────────────────────
training/datasets/**/*.wav
training/datasets/**/*.mp3
training/datasets/**/*.flac
training/datasets/**/*.ogg
training/datasets/**/*.m4a

# ── Trained model weights (large — download from RunPod) ─────────────────────
models/**/*.pt
models/**/*.pth
models/**/*.bin
# Keep folder structure and placeholder files
!models/**/place-models-here.txt

# ── Cover art (generated by DALL-E 3) ────────────────────────────────────────
covers/*.png

# ── Generated audio results ───────────────────────────────────────────────────
results/
*.wav
!training/datasets/**/
test_*.wav
trained_*.wav

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
install_log*.txt

# ── Repositories (cloned during install) ─────────────────────────────────────
repositories/audiocraft/
repositories/musicgen_trainer/

# ── OS & IDE ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
*.swp

# Uploads / temp
upload_r2.log
upload_r2_err.log
.cache/
